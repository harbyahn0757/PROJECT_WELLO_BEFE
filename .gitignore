# 김현우내과 건강검진 프로젝트 .gitignore

# ============================================================================
# 레퍼런스 폴더 제외
# ============================================================================
reference/

# ============================================================================
# Node.js 관련
# ============================================================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# ============================================================================
# React 빌드 관련
# ============================================================================
# Production builds
build/
dist/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================================================
# IDE 및 에디터 관련
# ============================================================================
# VS Code
.vscode/

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================================================
# macOS 관련
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================================================
# 로그 파일
# ============================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================================================
# 캐시 및 임시 파일
# ============================================================================
# ESLint cache
.eslintcache

# Parcel cache
.cache
.parcel-cache

# Next.js
.next

# Nuxt.js
.nuxt

# Gatsby
.cache/
# public — CRA 프로젝트에서는 public/ 필요. GLB 등 에셋 포함을 위해 models만 허용
public
!planning-platform/frontend/public/
!planning-platform/frontend/public/models/
!planning-platform/frontend/public/models/**

# ============================================================================
# 백엔드 관련 (향후 추가될 수 있음)
# ============================================================================
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# ============================================================================
# 기타
# ============================================================================
# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env.test

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# ============================================================================
# 프로젝트별 제외 파일
# ============================================================================
# 임시 텍스트 파일
*.textClipping

# 테스트 이미지 (필요시)
test-images/
temp/
planning-platform/backend/config.env
planning-platform/backend/logs_backup/

# ============================================================================
# 백업 및 시크릿 파일 추가 제외
# ============================================================================
# Backup files
*.bak
*.bak.*
*.backup
*.bak2
planning-platform/backend/schema_integration_backups/
planning-platform/backend/database_schema_backup*
planning-platform/backend/.env
planning-platform/backend/.env.*
planning-platform/backend/config.env.bak*
planning-platform/backoffice/src/**/*.bak*
planning-platform/backoffice/src/**/*.backup

# ============================================================================
# Claude Code
# ============================================================================
planning-platform/.claude/settings.local.json
planning-platform/.claude/skills
planning-platform/.claude/commands
planning-platform/.claude/rules

